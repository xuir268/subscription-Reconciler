{
  "uid": "subscription-reconciler",
  "title": "Subscription Reconciler",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Request Rate",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(rate(subscription_api_requests_total[1m]))"}]
    },
    {
      "type": "stat",
      "title": "5xx Rate",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(rate(subscription_api_requests_total{status=~\"5..\"}[1m]))"}]
    },
    {
      "type": "stat",
      "title": "Blocked By Rate Limit",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(rate(subscription_api_rate_limiter_total{result=\"blocked\"}[1m]))"}]
    },
    {
      "type": "stat",
      "title": "Goroutines",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "go_goroutines"}]
    },
    {
      "type": "timeseries",
      "title": "Requests By Status",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (status) (rate(subscription_api_requests_total[1m]))"}]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(subscription_api_request_duration_seconds_bucket[5m])))"}]
    },
    {
      "type": "timeseries",
      "title": "Memory",
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 8},
      "targets": [
        {"expr": "go_memstats_heap_alloc_bytes", "legendFormat": "heap alloc"},
        {"expr": "go_memstats_heap_sys_bytes", "legendFormat": "heap sys"}
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU",
      "gridPos": {"x": 8, "y": 12, "w": 8, "h": 8},
      "targets": [{"expr": "rate(process_cpu_seconds_total[1m])"}]
    },
    {
      "type": "timeseries",
      "title": "GC Pause Rate",
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 8},
      "targets": [{"expr": "rate(go_gc_duration_seconds_sum[1m])"}]
    },
    {
      "type": "timeseries",
      "title": "Request Cache",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (result) (rate(subscription_api_request_cache_total[1m]))"}]
    },
    {
      "type": "timeseries",
      "title": "Carrier Poll Results",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (status) (rate(subscription_carrier_poll_total[1m]))"}]
    },
    {
      "type": "timeseries",
      "title": "Timeline Endpoint Request Rate",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (status) (rate(subscription_api_requests_total{path=\"/users/{id}/timeline\"}[1m]))", "legendFormat": "{{status}}"}]
    },
    {
      "type": "stat",
      "title": "Notifications Sent (total)",
      "gridPos": {"x": 12, "y": 28, "w": 6, "h": 8},
      "targets": [{"expr": "subscription_notifications_sent_total"}]
    },
    {
      "type": "stat",
      "title": "Carrier Last Batch Size",
      "gridPos": {"x": 18, "y": 28, "w": 6, "h": 8},
      "targets": [{"expr": "subscription_carrier_last_batch_size"}]
    }
  ]
}
